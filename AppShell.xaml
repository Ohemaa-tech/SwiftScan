<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SwiftScan.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SwiftScan"
    xmlns:views="clr-namespace:SwiftScan.Views"
    Title="SwiftScan"
    FlyoutBehavior="Disabled">

    <!-- The ShellContents represent the pages available in the navigation stack -->
    <ShellContent
        Title="First Time Setup"
        ContentTemplate="{DataTemplate views:FirstTimeSetupPage}"
        Route="FirstTimeSetupPage" />

    <ShellContent
        Title="Security Lock"
        ContentTemplate="{DataTemplate views:PinLockPage}"
        Route="PinLockPage" />

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
