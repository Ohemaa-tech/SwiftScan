<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SwiftScan.ViewModels"
             x:Class="SwiftScan.Views.PinLockPage"
             x:DataType="vm:PinLockViewModel"
             Title="Security Lock"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <ContentPage.Resources>
        <Style x:Key="KeypadButton" TargetType="Button">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HeightRequest" Value="72" />
            <Setter Property="WidthRequest" Value="72" />
            <Setter Property="CornerRadius" Value="36" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style x:Key="KeypadActionButton" TargetType="Button" BasedOn="{StaticResource KeypadButton}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray950}}" />
            <Setter Property="TextColor" Value="{StaticResource Primary}" />
        </Style>
    </ContentPage.Resources>

    <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="CenterAndExpand" HorizontalOptions="Center" MaximumWidthRequest="400">
        
        <!-- App Logo / Icon -->
        <Border WidthRequest="70" 
                HeightRequest="70" 
                StrokeShape="RoundRectangle 35" 
                BackgroundColor="{StaticResource Primary}"
                StrokeThickness="0"
                HorizontalOptions="Center"
                Margin="0,0,0,10">
            <Label Text="🔒" 
                   FontSize="30" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" />
        </Border>

        <!-- Titles -->
        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
            <Label Text="Enter Admin PIN"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                   HorizontalOptions="Center" />
            <Label Text="System Locked"
                   FontSize="13"
                   TextColor="{StaticResource Gray500}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- PIN Dots Display -->
        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
            <Label Text="{Binding PinMask}"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   CharacterSpacing="10" />
            
            <Label Text="{Binding ErrorMessage}"
                   FontSize="14"
                   TextColor="Red"
                   IsVisible="{Binding HasError}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Numeric Keypad Grid -->
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              ColumnDefinitions="*,*,*"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              Margin="0,20,0,0">
            
            <!-- Row 1 -->
            <Button Grid.Row="0" Grid.Column="0" Text="1" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="1" />
            <Button Grid.Row="0" Grid.Column="1" Text="2" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="2" />
            <Button Grid.Row="0" Grid.Column="2" Text="3" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="3" />

            <!-- Row 2 -->
            <Button Grid.Row="1" Grid.Column="0" Text="4" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="4" />
            <Button Grid.Row="1" Grid.Column="1" Text="5" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="5" />
            <Button Grid.Row="1" Grid.Column="2" Text="6" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="6" />

            <!-- Row 3 -->
            <Button Grid.Row="2" Grid.Column="0" Text="7" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="7" />
            <Button Grid.Row="2" Grid.Column="1" Text="8" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="8" />
            <Button Grid.Row="2" Grid.Column="2" Text="9" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="9" />

            <!-- Row 4 -->
            <Button Grid.Row="3" Grid.Column="0" Text="CLR" Style="{StaticResource KeypadActionButton}" Command="{Binding ClearCommand}" />
            <Button Grid.Row="3" Grid.Column="1" Text="0" Style="{StaticResource KeypadButton}" Command="{Binding PressKeyCommand}" CommandParameter="0" />
            <Button Grid.Row="3" Grid.Column="2" Text="DEL" Style="{StaticResource KeypadActionButton}" Command="{Binding DeleteCommand}" />

        </Grid>

    </VerticalStackLayout>
</ContentPage>
